---
import RootLayout from '@/layouts/RootLayout.astro';
import Entry from '@/components/entry';
import { guardArea } from '@/lib/requireAuth';
const __guard = await guardArea(Astro.request, 'admin');
if (__guard) return Astro.redirect(__guard);
---
<RootLayout title="Fitvang — Admin">
  <Entry client:load view="admin/home" />
</RootLayout>
