---
import RootLayout from '@/layouts/RootLayout.astro';
import Entry from '@/components/entry';
import { requireAuth } from '@/lib/requireAuth';
const { user: authUser, redirect } = await requireAuth(Astro.request, ['super_admin', 'coach']);
if (redirect) return Astro.redirect(redirect);
const user = { id: authUser!.sub, nombre: authUser!.nombre, email: authUser!.email, rol: authUser!.rol };
---
<RootLayout title="Fitvang — Coach">
  <Entry client:load view="coach/home" user={user} />
</RootLayout>
