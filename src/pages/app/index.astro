---
import RootLayout from '@/layouts/RootLayout.astro';
import Entry from '@/components/entry';
const u = Astro.locals.user!;
const user = { id: u.sub, nombre: u.nombre, email: '', rol: u.rol };
---
<RootLayout title="Fitvang — Mi espacio">
  <Entry client:load view="user/home" user={user} />
</RootLayout>
