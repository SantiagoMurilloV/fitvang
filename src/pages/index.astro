---
import RootLayout from '@/layouts/RootLayout.astro';
import LoginForm from '@/components/auth/LoginForm';

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000';
const next = Astro.url.searchParams.get('next') ?? undefined;

function roleTarget(user: { rol: string; esAcudiente?: boolean }) {
  if (user.rol === 'super_admin') return '/admin';
  if (user.rol === 'coach') return '/coach';
  if (user.esAcudiente) return '/acudiente';
  return '/app';
}

function nextIsAllowed(next: string | undefined, user: { rol: string; esAcudiente?: boolean }): boolean {
  if (!next) return false;
  if (user.rol === 'super_admin') return true;
  if (user.rol === 'coach') return next.startsWith('/coach') || next.startsWith('/admin');
  if (user.esAcudiente) return next.startsWith('/acudiente');
  return next.startsWith('/app');
}

try {
  const res = await fetch(`${API_URL}/api/auth/me`, {
    headers: { cookie: Astro.request.headers.get('cookie') ?? '' },
  });
  if (res.ok) {
    const { user } = await res.json() as { user: { rol: string; esAcudiente?: boolean } };
    const target = roleTarget(user);
    const dest = nextIsAllowed(next, user) ? next! : target;
    return Astro.redirect(dest);
  }
} catch {
  // no session — show login
}
---
<RootLayout title="Fitvang — Entrar">
  <main class="relative min-h-screen flex flex-col items-center justify-center p-6 overflow-hidden">
    <!-- Ambient depth layers -->
    <div class="pointer-events-none absolute -top-48 -left-48 h-[700px] w-[700px] rounded-full bg-primary/[0.06] blur-[140px]" />
    <div class="pointer-events-none absolute -bottom-40 -right-40 h-[500px] w-[500px] rounded-full bg-primary/[0.05] blur-[120px]" />
    <div class="pointer-events-none absolute h-[350px] w-[350px] rounded-full bg-primary/[0.04] blur-[90px]" />
    <!-- Subtle grid texture -->
    <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.015)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.015)_1px,transparent_1px)] bg-[size:48px_48px]" />

    <LoginForm client:load next={next} />
  </main>
</RootLayout>
