---
import RootLayout from '@/layouts/RootLayout.astro';
import Entry from '@/components/entry';
import { guardArea } from '@/lib/requireAuth';
const __guard = await guardArea(Astro.request, 'acudiente');
if (__guard.redirect) return Astro.redirect(__guard.redirect);
---
<RootLayout title="Fitvang — Perfil">
  <Entry client:load view="acudiente/perfil" user={__guard.user} />
</RootLayout>
