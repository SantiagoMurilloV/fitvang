---
import "@/styles/global.css";
interface Props {
  title?: string;
}
const { title = "Fitvang" } = Astro.props;
---
<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
    <meta name="theme-color" content="#0D0D0D" />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- iOS PWA -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Fitvang" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />

    <!-- Android / Chrome -->
    <meta name="mobile-web-app-capable" content="yes" />

    <!-- Captura temprana del prompt de instalación PWA (Android/Chrome): el
         evento puede dispararse antes de que React hidrate, así que se guarda
         en window y se avisa con un evento propio al banner de instalación. -->
    <script is:inline set:html={`
      window.addEventListener('beforeinstallprompt', function (e) {
        e.preventDefault();
        window.__fvInstallPrompt = e;
        window.dispatchEvent(new Event('fv-install-ready'));
      });
    `} />

    <!-- General -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/icons/icon-192.png" />
    <meta name="description" content="Club de entrenamiento funcional y fútbol funcional — Cali" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-background text-foreground" style={import.meta.env.DEV ? '' : 'opacity:0;transition:opacity 0.12s ease;'}>

    <!-- PWA splash — solo en producción (en dev cubría todo de negro si un script fallaba) -->
    {import.meta.env.PROD && (
      <div id="pwa-splash" style="position:fixed;inset:0;z-index:99999;background:#0D0D0D;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;transition:opacity 0.2s ease;">
        <img src="/icons/icon-192.png" alt="Fitvang" style="width:72px;height:72px;border-radius:20px;box-shadow:0 0 32px rgba(61,196,219,0.3);" />
        <div style="width:120px;height:3px;background:rgba(255,255,255,0.08);border-radius:9px;overflow:hidden;">
          <div id="splash-bar" style="height:100%;width:0%;background:linear-gradient(90deg,#3DC4DB,#4DD4E8);border-radius:9px;transition:width 0.6s cubic-bezier(.4,0,.2,1);"></div>
        </div>
      </div>
    )}

    <!-- Page transition bar -->
    <div id="page-loader" style="position:fixed;top:0;left:0;right:0;z-index:9999;height:2px;pointer-events:none;">
      <div id="page-loader-bar" style="height:100%;width:0%;background:linear-gradient(90deg,#3DC4DB,#4DD4E8);border-radius:0 2px 2px 0;box-shadow:0 0 8px rgba(61,196,219,0.6);opacity:0;transition:opacity 0.15s ease;"></div>
    </div>

    <slot />

    {import.meta.env.PROD && (
      <script is:inline set:html={`
        if ('serviceWorker' in navigator) {
          window.addEventListener('load', function () {
            navigator.serviceWorker.register('/sw.js', { scope: '/' }).catch(function () {});
          });
        }
      `} />
    )}

    {import.meta.env.DEV && (
      <script is:inline set:html={`
        // En dev NO usamos el service worker: cachea módulos de Vite y rompe el HMR
        // (pantalla en negro al cambiar código). Lo desregistramos y limpiamos caché.
        if ('serviceWorker' in navigator) {
          navigator.serviceWorker.getRegistrations().then(function (regs) {
            var had = regs.length > 0;
            Promise.all(regs.map(function (r) { return r.unregister(); })).then(function () {
              if (window.caches && caches.keys) {
                return caches.keys().then(function (ks) { return Promise.all(ks.map(function (k) { return caches.delete(k); })); });
              }
            }).then(function () {
              if (had && !sessionStorage.getItem('fv-sw-cleared')) {
                sessionStorage.setItem('fv-sw-cleared', '1');
                location.reload();
              }
            });
          });
        }
      `} />
    )}

    <script>
      (function () {
        const body    = document.body;
        const bar     = document.getElementById('page-loader-bar') as HTMLElement;
        const splash  = document.getElementById('pwa-splash') as HTMLElement;
        const splashB = document.getElementById('splash-bar') as HTMLElement;

        // ── PWA Splash: animar barra y ocultar antes del fade-in ────────
        const isPwa = window.matchMedia('(display-mode: standalone)').matches
          || (window.navigator as any).standalone === true;

        if (isPwa && splash) {
          // Animación de carga: 0→70% rápido, luego ocultar con el fade-in
          splashB.style.width = '70%';
          setTimeout(() => { splashB.style.width = '100%'; }, 400);
          setTimeout(() => {
            splash.style.opacity = '0';
            setTimeout(() => { splash.style.display = 'none'; }, 220);
          }, 700);
        } else if (splash) {
          splash.style.display = 'none';
        }

        // ── Fade in on arrival ──────────────────────────────────────────
        requestAnimationFrame(() => requestAnimationFrame(() => {
          body.style.opacity = '1';
        }));

        // ── Progress bar ────────────────────────────────────────────────
        let raf: number | null = null;
        let prog = 0;

        function startBar() {
          bar.style.opacity = '1';
          prog = 0;
          bar.style.transition = 'none';
          bar.style.width = '0%';
          function tick() {
            prog += (80 - prog) * 0.08;
            bar.style.width = prog + '%';
            raf = requestAnimationFrame(tick);
          }
          raf = requestAnimationFrame(tick);
        }

        function finishBar() {
          if (raf) cancelAnimationFrame(raf);
          bar.style.transition = 'width 0.12s ease';
          bar.style.width = '100%';
          setTimeout(() => { bar.style.opacity = '0'; bar.style.width = '0%'; }, 180);
        }

        // ── Fade-out + bar on navigation ────────────────────────────────
        function onNavigate() {
          body.style.transition = 'opacity 0.1s ease';
          body.style.opacity = '0';
          startBar();
        }

        document.addEventListener('click', (e) => {
          const a = (e.target as Element)?.closest('a');
          if (!a) return;
          const href = a.getAttribute('href') ?? '';
          if (!href || href.startsWith('#') || href.startsWith('mailto:') || a.target === '_blank') return;
          if (href.startsWith('http') && !href.includes(location.hostname)) return;
          onNavigate();
        });

        window.addEventListener('beforeunload', onNavigate);

        window.addEventListener('pageshow', (e) => {
          if (e.persisted) { body.style.opacity = '1'; finishBar(); }
        });
      })();
    </script>
  </body>
</html>
