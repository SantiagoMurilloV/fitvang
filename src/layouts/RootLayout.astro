---
import "@/styles/global.css";
interface Props {
  title?: string;
}
const { title = "Fitvang" } = Astro.props;
---
<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0D0D0D" />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- iOS PWA -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Fitvang" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />

    <!-- Android / Chrome -->
    <meta name="mobile-web-app-capable" content="yes" />

    <!-- General -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/icons/icon-192.png" />
    <meta name="description" content="Club de entrenamiento funcional y fútbol funcional — Cali" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-background text-foreground" style="opacity:0;transition:opacity 0.25s ease;">
    <!-- Page transition bar -->
    <div id="page-loader" style="position:fixed;top:0;left:0;right:0;z-index:9999;height:2px;pointer-events:none;">
      <div id="page-loader-bar" style="height:100%;width:0%;background:linear-gradient(90deg,#3DC4DB,#4DD4E8);border-radius:0 2px 2px 0;box-shadow:0 0 10px rgba(61,196,219,0.7);opacity:0;transition:opacity 0.2s ease;"></div>
    </div>
    <slot />
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js', { scope: '/' }).catch(() => {});
        });
      }

      (function () {
        const body = document.body;
        const bar  = document.getElementById('page-loader-bar') as HTMLElement;

        // ── Fade in on arrival ──────────────────────────────────────────
        function fadeIn() {
          body.style.opacity = '1';
        }
        // requestAnimationFrame ensures paint happens before transition
        requestAnimationFrame(() => requestAnimationFrame(fadeIn));

        // ── Progress bar ────────────────────────────────────────────────
        let raf: number | null = null;
        let prog = 0;

        function startBar() {
          bar.style.opacity = '1';
          prog = 0;
          bar.style.transition = 'none';
          bar.style.width = '0%';

          function tick() {
            prog += (78 - prog) * 0.06;
            bar.style.width = prog + '%';
            raf = requestAnimationFrame(tick);
          }
          raf = requestAnimationFrame(tick);
        }

        function finishBar() {
          if (raf) cancelAnimationFrame(raf);
          bar.style.transition = 'width 0.15s ease';
          bar.style.width = '100%';
          setTimeout(() => { bar.style.opacity = '0'; bar.style.width = '0%'; }, 220);
        }

        // ── Fade-out + bar on navigation ────────────────────────────────
        function onNavigate() {
          body.style.transition = 'opacity 0.18s ease';
          body.style.opacity = '0';
          startBar();
        }

        // Link clicks
        document.addEventListener('click', (e) => {
          const a = (e.target as Element)?.closest('a');
          if (!a) return;
          const href = a.getAttribute('href') ?? '';
          if (!href || href.startsWith('#') || href.startsWith('mailto:') || a.target === '_blank') return;
          if (href.startsWith('http') && !href.includes(location.hostname)) return;
          onNavigate();
        });

        // Programmatic navigations (location.href = ..., replace, etc.)
        window.addEventListener('beforeunload', onNavigate);

        // Clean up bar if user presses back/forward
        window.addEventListener('pageshow', (e) => {
          if (e.persisted) { body.style.opacity = '1'; finishBar(); }
        });
      })();
    </script>
  </body>
</html>
